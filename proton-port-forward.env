# Port-forward loop settings.

STATE_FILE=/run/proton/proton-port.state
QBITTORRENT_ENV_FILE=/etc/proton/qbittorrent.env
CHECK_INTERVAL=45
MAX_FAILURES=5
# How many consecutive transient NAT-PMP windows a proven-good server is kept
# and retried in place (preserving its forwarded port) before falling back to a
# full reconnect. Prevents a slow server from thrashing the qBittorrent port.
PROVEN_TRANSIENT_MAX_KEEPS=5
PORT_LEASE_SECONDS=60
