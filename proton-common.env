# Shared settings for the Proton systemd services.

KILLSWITCH_BACKEND=auto
WG_PROFILE=proton
VPN_INTERFACE=proton
NATPMP_GATEWAY=10.2.0.1
STATE_DIR=/run/proton
WG_RUNTIME_DIR=/etc/wireguard/proton-runtime
SERVER_SELECTION_FILE=/run/proton/current-server.env
SERVER_POOL_ENABLED=on
WG_POOL_DIR=/etc/wireguard/proton-pool
WG_IPV6_ENABLED=off
VPN_FWMARK=0xca6c
VPN_TABLE=51820
BYPASS_TCP_PORTS=22,3389
BYPASS_UDP_PORTS=3389
DOCKER_NETWORK_CIDR=192.168.96.0/20
MANAGEMENT_ALLOWED_CIDRS=192.168.237.0/24,66.45.154.85/32
MANAGEMENT_TCP_PORTS=22,3389
MANAGEMENT_UDP_PORTS=3389
BAD_SERVER_COOLDOWN=900
SERVER_SWITCH_MIN_IMPROVEMENT_MS=10
SERVER_SWITCH_DEGRADED_LATENCY_MS=75
PING_TIMEOUT_SECONDS=1
PING_COUNT=1
SERVER_POOL_STRICT_LINT=on
WG_EXPECTED_DNS=10.2.0.1,2a07:b944::2:1
WG_LINT_ALLOW_MISSING_DNS=off
PORT_FORWARD_REQUIRED=on
PF_CAPABLE_PROFILES_FILE=/etc/proton/pf-capable-profiles.tsv
PF_INCAPABLE_PROFILES_FILE=/etc/proton/pf-incapable-profiles.tsv
RECOVERY_LOCK_FILE=/run/proton/recovery.lock
MANAGE_RESOLVED_DNS=auto
RESOLVED_DNS_ROUTE_DOMAIN=~.
