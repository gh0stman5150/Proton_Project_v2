# Shared settings for the Proton systemd services.

KILLSWITCH_BACKEND=nftables
WG_PROFILE=proton
VPN_INTERFACE=proton
NATPMP_GATEWAY=10.2.0.1
STATE_DIR=/run/proton
WG_RUNTIME_DIR=/etc/wireguard/proton-runtime
SERVER_SELECTION_FILE=/run/proton/current-server.env
SERVER_POOL_ENABLED=on
WG_POOL_DIR=/etc/wireguard/proton-pool
WG_IPV6_ENABLED=off
# Keeps the Proton session (and its NAT-PMP mapping) warm between port-forward
# polls so natpmpc stops timing out on idle tunnels. Set 0 to disable.
WG_PERSISTENT_KEEPALIVE=25
VPN_FWMARK=0xca6c
VPN_TABLE=51820
BYPASS_TCP_PORTS=22,3389
BYPASS_UDP_PORTS=3389
DOCKER_NETWORK_CIDR=192.168.96.0/20
# Leave empty until the external Docker network is recreated in a maintenance
# window with this exact IPv6 subnet and nftables enforcement is preinstalled.
DOCKER_NETWORK_CIDR6=
# Exactly one IPv6-capable instance owns fallback routing for non-qBittorrent
# Docker traffic. qBittorrent receives a higher-priority per-container rule.
DOCKER_IPV6_FALLBACK_INSTANCE=sonarr
MANAGEMENT_ALLOWED_CIDRS=192.168.237.0/24,66.45.154.85/32
MANAGEMENT_TCP_PORTS=22,3389
MANAGEMENT_UDP_PORTS=3389
BAD_SERVER_COOLDOWN=900
SERVER_SWITCH_MIN_IMPROVEMENT_MS=10
SERVER_SWITCH_DEGRADED_LATENCY_MS=75
PING_TIMEOUT_SECONDS=1
PING_COUNT=1
SERVER_POOL_STRICT_LINT=on
WG_EXPECTED_DNS=10.2.0.1,2a07:b944::2:1
WG_LINT_ALLOW_MISSING_DNS=off
PORT_FORWARD_REQUIRED=on
PF_CAPABLE_PROFILES_FILE=/etc/proton/pf-capable-profiles.tsv
PF_INCAPABLE_PROFILES_FILE=/etc/proton/pf-incapable-profiles.tsv
# Consecutive port-forward incapability strikes before a pool server is evicted
# (added to the incapable list and its pool config deleted). Strikes reset the
# moment a server proves it can forward a port.
PF_INCAPABLE_STRIKES_FILE=/run/proton/pf-incapable-strikes.tsv
PF_INCAPABLE_STRIKE_THRESHOLD=3
RECOVERY_LOCK_FILE=/run/proton/recovery.lock
MANAGE_RESOLVED_DNS=auto
RESOLVED_DNS_ROUTE_DOMAIN=~.
